<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp">

    <ImageView
        android:id="@+id/img_train3"
        android:layout_width="180dp"
        android:layout_height="180dp"
        android:src="@drawable/logo1"
        android:contentDescription="train"
        android:scaleType="centerInside"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="48dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/tv_title3"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Siap Berangkat?"
        android:textColor="#174A87"
        android:textSize="22sp"
        android:fontFamily="sans-serif-medium"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/img_train3"
        android:layout_marginTop="20dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/tv_desc3"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Masuk untuk melihat tiket Anda, melakukan pemesanan, dan mengakses promo eksklusif."
        android:textColor="#7A8AA6"
        android:textSize="14sp"
        android:gravity="center"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/tv_title3"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_go_login"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:text="Masuk / Login"
        android:textAllCaps="false"
        android:textColor="@android:color/white"
        android:backgroundTint="@color/btn_blue"
        app:cornerRadius="12dp"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/tv_desc3"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Small hint -->
    <TextView
        android:id="@+id/tv_hint3"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Mulai pesan tiket Anda sekarang"
        android:textColor="#7A8AA6"
        android:textSize="12sp"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/btn_go_login"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>