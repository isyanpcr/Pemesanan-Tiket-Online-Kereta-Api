<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="0dp">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="0dp"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/btn_blue"
        android:title="Generate QR Code"
        android:titleTextColor="@android:color/white"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Row helper style: label left (fixed), control right (flex) -->

            <!-- Nama -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="96dp"
                    android:layout_height="wrap_content"
                    android:text="Nama"
                    android:textStyle="bold" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPersonName"
                        android:hint="Masukkan nama" />
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>

            <!-- Spacing -->
            <View android:layout_width="match_parent" android:layout_height="12dp" />

            <!-- Stasiun Asal -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="96dp"
                    android:layout_height="wrap_content"
                    android:text="Asal"
                    android:textStyle="bold" />

                <Spinner
                    android:id="@+id/spinnerOrigin"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1" />
            </LinearLayout>
            <TextView
                android:id="@+id/textOriginError"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Pilih stasiun asal"
                android:textColor="#B00020"
                android:visibility="gone"
                android:textSize="12sp"
                android:layout_marginTop="4dp"/>

            <View android:layout_width="match_parent" android:layout_height="12dp" />

            <!-- Stasiun Tujuan -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="96dp"
                    android:layout_height="wrap_content"
                    android:text="Tujuan"
                    android:textStyle="bold" />

                <Spinner
                    android:id="@+id/spinnerDestination"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1" />
            </LinearLayout>
            <TextView
                android:id="@+id/textDestinationError"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Pilih stasiun tujuan"
                android:textColor="#B00020"
                android:visibility="gone"
                android:textSize="12sp"
                android:layout_marginTop="4dp"/>

            <View android:layout_width="match_parent" android:layout_height="12dp" />

            <!-- Tanggal Berangkat (label left, icon + field right) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="96dp"
                    android:layout_height="wrap_content"
                    android:text="Tanggal"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:id="@+id/ivCalendar"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:padding="8dp"
                        android:src="@android:drawable/ic_menu_my_calendar"
                        android:contentDescription="Calendar"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        app:tint="@color/btn_blue" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_marginStart="8dp">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etDate"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:focusable="false"
                            android:clickable="true"
                            android:hint="Pilih tanggal" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>
            </LinearLayout>
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Ketuk ikon atau kotak untuk memilih tanggal"
                android:textSize="12sp"
                android:textColor="#666"
                android:layout_marginTop="6dp"/>

            <View android:layout_width="match_parent" android:layout_height="12dp" />

            <!-- Kelas -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="96dp"
                    android:layout_height="wrap_content"
                    android:text="Kelas"
                    android:textStyle="bold" />

                <Spinner
                    android:id="@+id/spinnerClass"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1" />
            </LinearLayout>
            <TextView
                android:id="@+id/textClassError"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Pilih kelas"
                android:textColor="#B00020"
                android:visibility="gone"
                android:textSize="12sp"
                android:layout_marginTop="4dp"/>

            <View android:layout_width="match_parent" android:layout_height="18dp" />

            <!-- Submit button -->
            <Button
                android:id="@+id/btnSubmit"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Submit"
                android:backgroundTint="@color/btn_blue"
                android:textColor="@android:color/white"
                android:layout_marginTop="6dp"
                android:elevation="4dp" />

            <!-- QR ImageView centered -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginTop="18dp"
                android:paddingBottom="24dp">

                <ImageView
                    android:id="@+id/ivQrCode"
                    android:layout_width="250dp"
                    android:layout_height="250dp"
                    android:background="#f0f0f0"
                    android:scaleType="center"
                    android:visibility="gone" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>