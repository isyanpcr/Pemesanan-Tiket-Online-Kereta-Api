<?xml version="1.0" encoding="utf-8"?>
<ripple xmlns:android="http://schemas.android.com/apk/res/android" android:color="#33FFFFFF">
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="12dp"/>
            <gradient
                android:angle="270"
                android:startColor="@color/purple_deep"
                android:centerColor="@color/gradient_start"
                android:endColor="@color/cta_end"
                android:type="linear"/>
            <stroke android:width="1dp" android:color="#22000000"/>
            <!-- Increased height for clearer labels -->
            <size android:height="64dp"/>
            <padding android:left="16dp" android:top="12dp" android:right="16dp" android:bottom="12dp"/>
        </shape>
    </item>
</ripple>
